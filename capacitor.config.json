{
  "appId": "com.gigscourt.app",
  "appName": "GigsCourt",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "hostname": "localhost",
    "allowNavigation": [
      "*.firebaseapp.com",
      "*.supabase.co",
      "*.imagekit.io",
      "*.paystack.co",
      "*.openstreetmap.org"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0,
      "launchAutoHide": true,
      "backgroundColor": "#C0392B"
    }
  },
  "android": {
    "allowMixedContent": true
  },
  "ios": {
    "contentInset": "always",
    "scheme": "http"
  }
}
